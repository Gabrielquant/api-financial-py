# Database (use localhost para rodar migrations/Beekeeper no host; use postgres quando a app rodar no Docker)
DATABASE_URL=postgresql://financial_user:financial_pass@localhost:5432/financial_db

# Cognito / JWT
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=your_user_pool_id
COGNITO_CLIENT_ID=your_client_id
COGNITO_CLIENT_SECRET=your_client_secret

# AWS (opcional; para AdminConfirmSignUp/AdminUpdateUserAttributes no registro)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# App
SECRET_KEY=your-secret-key-here
DEBUG=false
